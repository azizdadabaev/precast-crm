# ──────────────────────────────────────────────────────────────────────────
# Precast CRM — production environment template
#
# Copy to `.env` next to docker-compose.yml on the VPS:
#   cp .env.production.example .env
#
# Then fill in every value below. The bootstrap script does this for you;
# this file documents what it sets so you can change values later.
# ──────────────────────────────────────────────────────────────────────────

# ── Postgres (used to build DATABASE_URL inside docker-compose.yml) ───────
POSTGRES_USER=precast
POSTGRES_DB=precast
# REQUIRED. Generate with: openssl rand -hex 24
POSTGRES_PASSWORD=

# ── Auth ─────────────────────────────────────────────────────────────────
# REQUIRED. ≥32 chars. Generate with: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ── App URL ──────────────────────────────────────────────────────────────
# REQUIRED. While you're on a raw IP with no TLS:
#   NEXT_PUBLIC_APP_URL=http://<vps-ip>
# Once you have a domain + Caddy is issuing certs:
#   NEXT_PUBLIC_APP_URL=https://crm.yourdomain.com
NEXT_PUBLIC_APP_URL=

# ── Cookie security ──────────────────────────────────────────────────────
# Set to "false" while running on plain HTTP (no domain / no TLS) so the
# auth cookie is actually delivered to the browser. Once you switch Caddy
# to a domain (auto-HTTPS), remove this line or set it to "true".
COOKIE_SECURE=false

# ── Order cancellation password ──────────────────────────────────────────
# Non-admin users must enter this to cancel an order from the UI.
ORDER_CANCEL_PASSWORD=

# ── Blender Bridge ───────────────────────────────────────────────────────
# Owner-only personal feature. The self-hosted ws-bridge service accepts
# exactly one WebSocket client per restart, gated by this shared secret.
# Generate with: openssl rand -hex 32
# Paste the same value into the Blender addon preferences so the addon
# can connect to wss://<your-host>/ws?secret=<BRIDGE_SECRET>.
BRIDGE_SECRET=

# Telegram Business Inbox
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
INBOX_PASSWORD=
