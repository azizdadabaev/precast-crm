# Local Claude Code state — per-machine, not portable
.claude/

# TypeScript incremental build info
**/tsconfig.tsbuildinfo

# Build & tooling caches that may end up at the repo root if a tool runs from
# the wrong dir (e.g. `npx next build` invoked above the project)
.next/
**/.next/
node_modules/
**/node_modules/

# Production env file generated by scripts/deploy-bootstrap.sh on the VPS.
# Contains the JWT secret and DB password — never commit.
/.env
