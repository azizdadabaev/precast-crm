# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/precast_crm?schema=public"

# Auth — sign your own JWT secret (32+ chars). DO NOT use the example value in production.
JWT_SECRET="change-this-to-a-strong-secret-min-32-chars-long"
JWT_EXPIRES_IN="7d"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Order cancellation password — non-admin users must enter this to cancel an
# order from the UI. Admins can cancel without it. Change for production.
ORDER_CANCEL_PASSWORD="etalontbm"

# Blender Bridge — shared secret. Only the owner's Blender knows this and
# the value lives in the addon preferences. Generate with:
#   openssl rand -hex 32
# Only used by the ws-bridge service container (the Next.js app does not
# read this value — it talks to the bridge over the internal /flush endpoint).
BRIDGE_SECRET="change-this-to-a-strong-secret-min-32-chars-long"

# Telegram Business Inbox
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
INBOX_PASSWORD=
# Staging channel for "Send to chat" quote images. Business connections reject
# fresh media (BUSINESS_PEER_USAGE_MISSING), so the bot first posts the quote to
# a private channel it admins to get a Telegram file_id, then sends that file_id
# to the customer. Create a private channel, add the bot (@etalontbm_bot) as
# admin with Post permission, and put the channel id here (e.g. -1001234567890).
TELEGRAM_STAGING_CHAT_ID=

# Shared secret for the AI agent's server-to-server endpoints (agent webhook +
# /api/agent/approve). Generate with: openssl rand -hex 32
AGENT_SERVICE_TOKEN=

# HMAC secret that signs AI-agent price quotes (the quote_id). The order tool
# re-verifies a quote_id with this secret, so a tampered/invented price is
# rejected. Generate with: openssl rand -hex 32
QUOTE_SIGNING_SECRET=

# ── LLM provider keys (AI agent bake-off — see src/lib/agent/llm/models.ts) ──
# The agent is provider-agnostic; the owner picks the primary model after the
# Shadow-stage bake-off (spec §14). Set the keys for whichever providers you
# want in the bake-off. Voice-note transcription is fixed to Google/Gemini.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
# Stable key (from models.ts) of the model that drives conversations. Until the
# bake-off picks a winner, default to the quality flagship. e.g. claude-opus-4-8
AGENT_MODEL_KEY=claude-opus-4-8
# Telegram chat id of the internal STAFF group that receives the write-action
# Action Cards ([Approve]/[Reject]). Create a private group, add the bot, and
# put its id here (e.g. -1001234567890). Used once the agent may place orders.
AGENT_STAFF_CHAT_ID=
