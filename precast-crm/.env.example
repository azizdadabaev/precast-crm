# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/precast_crm?schema=public"

# Auth — sign your own JWT secret (32+ chars). DO NOT use the example value in production.
JWT_SECRET="change-this-to-a-strong-secret-min-32-chars-long"
JWT_EXPIRES_IN="7d"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Order cancellation password — non-admin users must enter this to cancel an
# order from the UI. Admins can cancel without it. Change for production.
ORDER_CANCEL_PASSWORD="etalontbm"

# Blender Bridge — shared secret. Only the owner's Blender knows this and
# the value lives in the addon preferences. Generate with:
#   openssl rand -hex 32
# Only used by the ws-bridge service container (the Next.js app does not
# read this value — it talks to the bridge over the internal /flush endpoint).
BRIDGE_SECRET="change-this-to-a-strong-secret-min-32-chars-long"

# Telegram Business Inbox
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
INBOX_PASSWORD=
# Public base URL Telegram uses to FETCH outgoing quote images (Send to chat).
# Business connections reject fresh uploads, so we send a URL instead. Prod:
# leave blank to use NEXT_PUBLIC_APP_URL. Local dev: set this to your public
# tunnel (e.g. https://xxxx.trycloudflare.com) — the one that serves localhost:3000.
TELEGRAM_PUBLIC_BASE_URL=
