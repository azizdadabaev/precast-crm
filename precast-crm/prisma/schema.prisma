// Precast Concrete CRM - Prisma Schema
// Beam-and-Block manufacturing system

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  ADMIN
  SALES
  ENGINEER
}

enum Language {
  UZ
  RU
}

enum DealStage {
  NEW_LEAD
  CONTACTED
  CALCULATION
  QUOTE_SENT
  WON
  LOST
}

enum DealStatus {
  OPEN
  WON
  LOST
}

enum ShapeType {
  RECTANGULAR
  TRAPEZOIDAL
  IRREGULAR
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

enum PaymentStatus {
  PAID
  PARTIAL
  UNPAID
}

// ─────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(SALES)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  deals Deal[] @relation("AssignedDeals")

  @@map("users")
}

model Client {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique
  location  String?
  language  Language @default(UZ)
  source    String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deals Deal[]

  @@index([phone])
  @@index([createdAt])
  @@map("clients")
}

model Deal {
  id           String     @id @default(cuid())
  clientId     String
  stage        DealStage  @default(NEW_LEAD)
  status       DealStatus @default(OPEN)
  value        Decimal    @default(0) @db.Decimal(14, 2)
  assignedToId String?
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  client     Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assignedTo User?     @relation("AssignedDeals", fields: [assignedToId], references: [id])
  projects   Project[]
  payments   Payment[]

  @@index([stage])
  @@index([status])
  @@index([clientId])
  @@map("deals")
}

model Project {
  id         String    @id @default(cuid())
  dealId     String
  name       String?
  shapeType  ShapeType @default(RECTANGULAR)
  dimensions Json // { width, length, lengths?: [], notes?: string }
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  deal         Deal          @relation(fields: [dealId], references: [id], onDelete: Cascade)
  calculations Calculation[]
  quotes       Quote[]

  @@index([dealId])
  @@map("projects")
}

model Calculation {
  id              String   @id @default(cuid())
  projectId       String
  name            String? // Room label (e.g. "Kitchen")
  // Inputs snapshot for reproducibility
  inputWidth      Decimal  @db.Decimal(10, 3)
  inputLength     Decimal  @db.Decimal(10, 3)
  // Engine outputs
  beamLength      Decimal  @db.Decimal(10, 3)
  rowsInitial     Int
  rowsFinal       Int
  beamCount       Int
  beamGroups      Json // [{ length, qty }]
  blocksPerRow    Int
  totalBlocks     Int
  actualLength    Decimal  @db.Decimal(10, 3)
  correctedLength Decimal  @db.Decimal(10, 3)
  coveredArea     Decimal  @db.Decimal(10, 3)
  delta           Decimal  @db.Decimal(10, 3)
  concreteVolume  Decimal  @db.Decimal(10, 3)
  // Manual overrides
  extraBeams      Int      @default(0)
  extraFillers    Int      @default(0)
  // Pricing (Excel replication)
  pricePerM2      Decimal? @db.Decimal(14, 2)
  totalSum        Decimal? @db.Decimal(14, 2)
  // Constants used (for audit)
  constants       Json
  createdAt       DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  quotes  Quote[]

  @@index([projectId])
  @@map("calculations")
}

model Quote {
  id            String      @id @default(cuid())
  projectId     String
  calculationId String?
  beamCost      Decimal     @default(0) @db.Decimal(14, 2)
  blockCost     Decimal     @default(0) @db.Decimal(14, 2)
  concreteCost  Decimal     @default(0) @db.Decimal(14, 2)
  deliveryCost  Decimal     @default(0) @db.Decimal(14, 2)
  otherCost     Decimal     @default(0) @db.Decimal(14, 2)
  totalPrice    Decimal     @default(0) @db.Decimal(14, 2)
  status        QuoteStatus @default(DRAFT)
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  calculation Calculation? @relation(fields: [calculationId], references: [id])

  @@index([projectId])
  @@index([status])
  @@map("quotes")
}

model Payment {
  id        String        @id @default(cuid())
  dealId    String
  amount    Decimal       @db.Decimal(14, 2)
  status    PaymentStatus @default(UNPAID)
  method    String?
  reference String?
  paidAt    DateTime?
  createdAt DateTime      @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@index([status])
  @@map("payments")
}

// Application-wide configuration. Stored in DB so that
// the calculation engine constants (TOLERANCE, prices, etc.)
// can be tuned without redeploy. The engine itself stays pure
// — values are passed in as arguments.
model AppConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt

  @@map("app_config")
}
