// Precast Concrete CRM - Prisma Schema
// Beam-and-Block manufacturing system

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  ADMIN
  SALES
  ENGINEER
}

enum Language {
  UZ
  RU
}

enum DealStage {
  NEW_LEAD
  CONTACTED
  CALCULATION
  QUOTE_SENT
  WON
  LOST
}

enum DealStatus {
  OPEN
  WON
  LOST
}

enum ShapeType {
  RECTANGULAR
  TRAPEZOIDAL
  IRREGULAR
}

enum LayoutPattern {
  GB    // Г-Б — alternating, equal beam and block rows
  BGB   // Б-Г-Б — extra closing beam
  GBG   // Г-Б-Г — extra closing block row
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

enum PaymentStatus {
  PAID
  PARTIAL
  UNPAID
}

// ─────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(SALES)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  deals Deal[] @relation("AssignedDeals")

  @@map("users")
}

model Client {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique
  location  String?
  language  Language @default(UZ)
  source    String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deals Deal[]

  @@index([phone])
  @@index([createdAt])
  @@map("clients")
}

model Deal {
  id           String     @id @default(cuid())
  clientId     String
  stage        DealStage  @default(NEW_LEAD)
  status       DealStatus @default(OPEN)
  value        Decimal    @default(0) @db.Decimal(14, 2)
  assignedToId String?
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  client     Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assignedTo User?     @relation("AssignedDeals", fields: [assignedToId], references: [id])
  projects   Project[]
  payments   Payment[]

  @@index([stage])
  @@index([status])
  @@index([clientId])
  @@map("deals")
}

model Project {
  id         String    @id @default(cuid())
  dealId     String
  name       String?
  shapeType  ShapeType @default(RECTANGULAR)
  dimensions Json // { width, length, lengths?: [], notes?: string }
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  deal         Deal          @relation(fields: [dealId], references: [id], onDelete: Cascade)
  calculations Calculation[]
  quotes       Quote[]

  @@index([dealId])
  @@map("projects")
}

model Calculation {
  id              String        @id @default(cuid())
  projectId       String
  name            String? // Room label (e.g. "Kitchen")

  // ── Inputs (snapshot for reproducibility) ──
  innerWidth      Decimal       @db.Decimal(10, 3)
  innerLength     Decimal       @db.Decimal(10, 3)
  bearing         Decimal       @default(0.15) @db.Decimal(10, 3)
  correction      Decimal       @default(0) @db.Decimal(10, 3)
  extraBeams      Int           @default(0)
  forceStartBeam  Boolean       @default(false)
  patternOverride LayoutPattern? // user-picked; null = auto

  // ── Pitch math ──
  pitches         Int
  remainder       Decimal       @db.Decimal(10, 3)
  pattern         LayoutPattern // chosen (after override + force_start_beam)
  patternAuto     LayoutPattern // what auto-pick would have chosen

  // ── Geometry ──
  beamLength      Decimal       @db.Decimal(10, 3)
  blocksPerRow    Int
  beamCount       Int           // includes pattern's extra beam AND extraBeams
  blockRows       Int
  totalBlocks     Int

  // Lengths (m)
  monolithLength  Decimal       @db.Decimal(10, 3) // physical span
  billedLength    Decimal       @db.Decimal(10, 3) // pitches × PITCH (for m² billing)

  // Areas (m²)
  monolithArea    Decimal       @db.Decimal(10, 3)
  billedArea      Decimal       @db.Decimal(10, 3)

  concreteVolume  Decimal       @db.Decimal(10, 3) // m³

  // ── Pricing snapshot (UZS) ──
  m2Price                 Decimal @db.Decimal(14, 2)
  extraBeamPricePerM      Decimal @db.Decimal(14, 2)
  m2Cost                  Decimal @db.Decimal(14, 2)
  patternExtraCost        Decimal @db.Decimal(14, 2)
  manualExtraBeamsCost    Decimal @db.Decimal(14, 2)
  subtotal                Decimal @db.Decimal(14, 2)

  createdAt       DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  quotes  Quote[]

  @@index([projectId])
  @@map("calculations")
}

model Quote {
  id              String      @id @default(cuid())
  projectId       String
  calculationId   String?
  // Pre-discount sum of all room subtotals on this project
  roomsSubtotal   Decimal     @default(0) @db.Decimal(14, 2)
  // Discount applied to grand total (0–100)
  discountPercent Decimal     @default(0) @db.Decimal(5, 2)
  discountAmount  Decimal     @default(0) @db.Decimal(14, 2)
  // Optional per-line costs preserved for future itemization
  deliveryCost    Decimal     @default(0) @db.Decimal(14, 2)
  otherCost       Decimal     @default(0) @db.Decimal(14, 2)
  // Final amount: roomsSubtotal − discountAmount + deliveryCost + otherCost
  totalPrice      Decimal     @default(0) @db.Decimal(14, 2)
  status          QuoteStatus @default(DRAFT)
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  calculation Calculation? @relation(fields: [calculationId], references: [id])

  @@index([projectId])
  @@index([status])
  @@map("quotes")
}

model Payment {
  id        String        @id @default(cuid())
  dealId    String
  amount    Decimal       @db.Decimal(14, 2)
  status    PaymentStatus @default(UNPAID)
  method    String?
  reference String?
  paidAt    DateTime?
  createdAt DateTime      @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@index([status])
  @@map("payments")
}

// Application-wide configuration. Stored in DB so that
// the calculation engine constants (TOLERANCE, prices, etc.)
// can be tuned without redeploy. The engine itself stays pure
// — values are passed in as arguments.
model AppConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt

  @@map("app_config")
}
