// Precast Concrete CRM - Prisma Schema
// Beam-and-Block manufacturing system

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

// Role values are PERMISSION TEMPLATES, not access controls. The actual
// access for a user comes from User.permissions (the source of truth).
// When adding a user, the operator picks a role to pre-fill the
// permissions checklist; after creation, the role is metadata only.
enum UserRole {
  OWNER       // template: full access incl. user.disable + user.editPermissions
  ADMIN       // template: management (no user.disable / user.editPermissions)
  SALES       // template: customer-facing operations
  INVENTORY   // template: warehouse
  DRIVER      // template: delivery
  ACCOUNTANT  // template: financial reporting
  CUSTOM      // no template — operator picks every permission manually
}

enum Language {
  UZ
  RU
}

enum DealStage {
  NEW_LEAD
  CONTACTED
  CALCULATION
  QUOTE_SENT
  WON
  LOST
}

enum DealStatus {
  OPEN
  WON
  LOST
}

enum ShapeType {
  RECTANGULAR
  TRAPEZOIDAL
  IRREGULAR
}

enum LayoutPattern {
  GB    // Г-Б — alternating, equal beam and block rows
  BGB   // Б-Г-Б — extra closing beam
  GBG   // Г-Б-Г — extra closing block row
}

enum ProjectStatus {
  DRAFT      // saved calculation, not yet placed as an order
  ORDERED    // an Order exists for this project
  ARCHIVED   // soft-deleted draft
}

enum OrderStatus {
  DRAFT           // reserved (drafts currently live on Project.status; included for future workflow flexibility)
  PLACED          // Буюртма Берилди — newly placed
  IN_PRODUCTION   // Ишлаб чиқарилмоқда
  LOADED          // truck photo taken, awaiting dispatch (single-truck path)
  DISPATCHED      // Жўнатилди — truck en route with driver
  DELIVERED       // Етказиб берилди
  CANCELED        // Бекор қилинди
}

// Tracks how much of an Order's totalPrice is confirmed-paid.
// Recomputed every time a Payment moves to/from CONFIRMED.
enum OrderPaymentState {
  AWAITING_PAYMENT
  PARTIALLY_PAID
  FULLY_PAID
}

// New three-state lifecycle. PENDING → CONFIRMED (owner) | REJECTED (owner).
enum PaymentStatus {
  PENDING_CONFIRMATION
  CONFIRMED
  REJECTED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CLICK
  PAYME
  OTHER
}

enum DiscrepancyStatus {
  OPEN                   // shortfall flagged, not yet resolved
  RESOLVED_RECOVERED     // shortfall later collected (customer paid the rest)
  RESOLVED_DISCOUNT      // owner approved as a retroactive discount
  RESOLVED_WRITEOFF      // owner wrote off as a loss
  DISPUTED               // disputed with driver/operator (HR / disciplinary)
}

enum OrderEventType {
  ORDER_PLACED
  STATUS_CHANGED
  SCHEDULED_DATE_CHANGED
  DISCOUNT_APPLIED
  ORDER_CANCELED
  ORDER_EDITED              // post-placement edit of rooms / pricing snapshot
  NOTE_ADDED
  STOCK_WARNING
  // Cash custody / dispatch lifecycle events:
  ORDER_DISPATCHED          // driver assigned, order on the road
  DISPATCH_RETURNED         // driver back at office (or delivery rejected)
  PAYMENT_RECORDED          // operator entered a Payment row (PENDING_CONFIRMATION)
  PAYMENT_HANDED_OVER       // physical cash handed from driver to office
  PAYMENT_CONFIRMED         // owner confirmed amount is correct
  PAYMENT_REJECTED          // owner rejected the recorded payment
  PAYMENT_ADJUSTED          // confirmer changed the amount (originalAmount kept)
  DISCREPANCY_OPENED        // confirmer flagged a shortfall to track
  DISCREPANCY_RESOLVED      // owner resolved it (recovered/discount/writeoff/disputed)
  ORDER_LOADED              // single-truck: photo taken, status → LOADED
  SHIPMENT_CREATED          // split: new Shipment row added
  SHIPMENT_LOADED           // split: shipment photo + counts saved
  SHIPMENT_DISPATCHED       // split: shipment truck left the yard
  SHIPMENT_DELIVERED        // split: shipment confirmed delivered
}

enum ShipmentStatus {
  PENDING     // created, not yet loaded
  LOADED      // photo + counts saved
  DISPATCHED  // truck left the yard
  DELIVERED   // confirmed delivered to client
}

enum InventoryKind {
  BEAM
  BLOCK
}

enum StockMovementReason {
  PRODUCTION
  DELIVERY
  MANUAL_ADJUSTMENT
  CANCELLATION_RESTOCK
}

// Blender Bridge — owner-only feature that pushes saved rooms to a
// locally-running Blender instance via a self-hosted WebSocket
// service. PENDING → DELIVERED|FAILED is the only lifecycle.
enum DrawingRequestStatus {
  PENDING
  DELIVERED
  FAILED
}

// Privacy gate for the contact-export feature: a client can only be
// included in an export if their consent state is GRANTED. NOT_ASKED is
// the default for existing rows and any new client until the operator
// explicitly records the answer.
enum ReferenceConsent {
  NOT_ASKED
  GRANTED
  DENIED
}

// ─────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  // Login identifier derived from name: "Азиз", "Азиз 2", etc.
  // Nullable during the initial schema push; seed.ts populates all rows.
  loginName    String?  @unique
  // PIN-based auth (bcrypt of 4-digit PIN). Null until seed/reset sets it.
  pinHash      String?
  email        String?  @unique  // optional metadata, no longer used for login
  passwordHash String?           // legacy; null for users created after PIN migration
  // role is the TEMPLATE label this user was created from. Source of
  // truth for access is `permissions`, not `role`.
  role         UserRole @default(SALES)
  // The actual access control. Strings from src/lib/permissions.ts ACTIONS.
  permissions  String[] @default([])
  isActive     Boolean  @default(true)
  // Forces a /change-password redirect on first login after creation
  // or after an admin reset.
  mustChangePassword Boolean   @default(true)
  lastLogin    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdById  String?

  deals             Deal[]             @relation("AssignedDeals")
  orderEvents       OrderEvent[]
  productionEntries ProductionEntry[]
  stockMovements    StockMovement[]
  exportEvents      ExportEvent[]

  // Cash-custody back-relations
  dispatchedDispatches  Dispatch[]    @relation("DispatchDispatcher")
  recordedPayments      Payment[]     @relation("PaymentRecorder")
  handedOverToOfficeBy  Payment[]     @relation("PaymentHandedOverTo")
  confirmedPayments     Payment[]     @relation("PaymentConfirmer")
  rejectedPayments      Payment[]     @relation("PaymentRejecter")
  reportedDiscrepancies Discrepancy[] @relation("DiscrepancyReporter")
  resolvedDiscrepancies Discrepancy[] @relation("DiscrepancyResolver")

  // Self-relation: who created this user, and what users this user has created
  createdBy             User?  @relation("UserCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdUsers          User[] @relation("UserCreatedBy")

  // Audit-log back-relations
  auditEntriesAsActor   UserAuditLog[] @relation("UserAuditActor")
  auditEntriesAsTarget  UserAuditLog[] @relation("UserAuditTarget")

  // System-wide audit log (AuditLog table) — entries this user is the
  // actor of. Distinct from UserAuditLog above which is user-account
  // changes only.
  systemAuditEntries    AuditLog[] @relation("AuditLogActor")

  // Blender Bridge — drawing requests this user created.
  drawingRequests       DrawingRequest[]

  shipmentsDispatched   Shipment[] @relation("ShipmentDispatcher")

  // Comments authored / moderated by this user
  authoredComments   Comment[] @relation("CommentAuthor")
  deletedComments    Comment[] @relation("CommentDeleter")

  // In-app notifications targeted at this user
  notifications      Notification[]

  // Gallery — photos this user uploaded
  uploadedPhotos     GalleryPhoto[]

  // Газоблок (aerated-block) line — back-relations
  gazoblokProductionEntries GazoblokProductionEntry[]
  gazoblokStockMovements    GazoblokStockMovement[]
  gazoblokOrderEvents       GazoblokOrderEvent[]
  gazoblokPaymentsRecorded  GazoblokPayment[] @relation("GazoblokPaymentRecorder")
  gazoblokPaymentsConfirmed GazoblokPayment[] @relation("GazoblokPaymentConfirmer")

  @@map("users")
}

// Append-only audit log for user lifecycle events: created, permissions
// changed, role template changed, disabled, enabled, password reset.
// No UI in this PR — pure data persistence so when the audit history
// is needed later, it's there.
model UserAuditLog {
  id        String   @id @default(cuid())
  userId    String   // user being modified
  actorId   String   // user doing the modifying
  action    String   // "created" | "permissions_changed" | "role_changed"
                     //  | "disabled" | "enabled" | "password_reset"
  oldValue  String?  // JSON snapshot of previous state
  newValue  String?  // JSON snapshot of new state
  createdAt DateTime @default(now())

  user  User @relation("UserAuditTarget", fields: [userId],  references: [id], onDelete: Cascade)
  actor User @relation("UserAuditActor",  fields: [actorId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([actorId, createdAt])
  @@map("user_audit_log")
}

// System-wide audit log. Records who-did-what-when across the whole CRM
// (project saves, order placements, status changes, dispatches, payments,
// drawings, etc.). Distinct from UserAuditLog (which is scoped to user-
// account changes) and OrderEvent (which is scoped to one order's
// lifecycle) — this is the global owner-only feed.
//
// Writes are best-effort fire-and-forget from route handlers via
// `recordAudit()` in src/lib/audit.ts; failures are logged but never
// surface as a 5xx to the user. The log is append-only by convention;
// there is no UPDATE/DELETE path in the helper.
model AuditLog {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  userId     String?  // nullable for system-triggered events (cron, bridge writeback)
  action     String   // e.g. "project.create", "order.place", "order.status.change"
  targetType String?  // e.g. "project", "order", "payment", "user"
  targetId   String?  // affected entity id (no FK — survives target deletion)
  message    String?  // short human-readable summary
  metadata   Json?    // structured extras (oldValue, newValue, etc.)

  user User? @relation("AuditLogActor", fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId])
  @@map("audit_log")
}

model Client {
  id        String   @id @default(cuid())
  name      String
  // Stored DIGITS-ONLY for stable lookup/dedup. Display formats it back.
  phone     String   @unique
  address   String?  // "Манзил" (renamed from `location`)
  language  Language @default(UZ)
  source    String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Reference-export privacy gate: GRANTED means the client agreed to be
  // listed when an operator exports contacts for a new prospect to visit
  // their finished slab. NOT_ASKED is the default — operators must
  // explicitly mark the answer.
  referenceConsent  ReferenceConsent @default(NOT_ASKED)
  consentNote       String?
  consentUpdatedAt  DateTime?

  deals    Deal[]
  projects Project[]
  orders   Order[]
  gazoblokOrders GazoblokOrder[]

  @@index([phone])
  @@index([createdAt])
  @@index([referenceConsent])
  @@map("clients")
}

model Deal {
  id           String     @id @default(cuid())
  clientId     String
  stage        DealStage  @default(NEW_LEAD)
  status       DealStatus @default(OPEN)
  value        Decimal    @default(0) @db.Decimal(14, 2)
  assignedToId String?
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  client     Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assignedTo User?     @relation("AssignedDeals", fields: [assignedToId], references: [id])
  projects   Project[]

  @@index([stage])
  @@index([status])
  @@index([clientId])
  @@map("deals")
}

model Project {
  id         String        @id @default(cuid())
  // Optional now: Calculations page can save a draft BEFORE a Deal exists.
  // The Deal is materialized when an order is placed.
  dealId     String?
  // Hardened client link (set when ordered, or when the operator picks an
  // existing client during the call). Null while we have only tentative info.
  clientId   String?

  // Optional link back to the Telegram conversation this quote was
  // calculated from (inbox feature). SetNull so deleting a chat never
  // deletes the quote it produced. Only set by callers with inbox.access.
  conversationId String?

  name       String?
  // Monotonically increasing identifier displayed as "NNNND" — the
  // "D" suffix brands the row as a saved draft, so an operator
  // skimming downloads / chat history can tell drafts apart from
  // real orders. Assigned at create time in POST /api/projects.
  // Nullable so existing pre-feature rows can be backfilled lazily.
  draftNumber Int?         @unique
  shapeType  ShapeType     @default(RECTANGULAR)
  dimensions Json
  status     ProjectStatus @default(DRAFT)

  // Tentative client info captured during the phone call.
  // Once the order is placed (or operator picks an existing client),
  // this gets reconciled into a Client row and these fields are cleared.
  tentativeClientName    String?
  tentativeClientPhone   String? // stored DIGITS-ONLY for dedup
  tentativeClientAddress String?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  deal         Deal?         @relation(fields: [dealId], references: [id], onDelete: SetNull)
  client       Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  calculations Calculation[]
  orders       Order[]
  drawingRequests DrawingRequest[]
  comments     Comment[]

  @@index([status])
  @@index([dealId])
  @@index([clientId])
  @@index([conversationId])
  @@index([tentativeClientPhone])
  @@map("projects")
}

model Calculation {
  id              String        @id @default(cuid())
  projectId       String
  name            String? // Room label (e.g. "Kitchen")

  // ── Inputs (snapshot for reproducibility) ──
  innerWidth      Decimal       @db.Decimal(10, 3)
  innerLength     Decimal       @db.Decimal(10, 3)
  bearing         Decimal       @default(0.15) @db.Decimal(10, 3)
  correction      Decimal       @default(0) @db.Decimal(10, 3)
  extraBeams      Int           @default(0)
  forceStartBeam  Boolean       @default(false)
  patternOverride LayoutPattern? // user-picked; null = auto

  // ── Pitch math ──
  pitches         Int
  remainder       Decimal       @db.Decimal(10, 3)
  pattern         LayoutPattern // chosen (after override + force_start_beam)
  patternAuto     LayoutPattern // what auto-pick would have chosen

  // ── Geometry ──
  beamLength      Decimal       @db.Decimal(10, 3)
  blocksPerRow    Int
  beamCount       Int
  blockRows       Int
  totalBlocks     Int

  monolithLength  Decimal       @db.Decimal(10, 3)
  billedLength    Decimal       @db.Decimal(10, 3)

  monolithArea    Decimal       @db.Decimal(10, 3)
  billedArea      Decimal       @db.Decimal(10, 3)

  concreteVolume  Decimal       @db.Decimal(10, 3)

  // ── Pricing snapshot (UZS) ──
  // m2Price is the EFFECTIVE rate used for m2Cost / subtotal — i.e. the
  // operator's chosen tier when m2PriceOverride = true, otherwise the
  // engine's auto-picked tier from beam_length. m2PriceOverride flags
  // the row as a deliberate non-default; m2PriceReason carries the
  // operator's optional explanation. The auto-picked rate is recoverable
  // at any time by calling tierPrice(beam_length, M2_PRICE_TIERS), so we
  // don't store it separately.
  m2Price                 Decimal @db.Decimal(14, 2)
  m2PriceOverride         Boolean @default(false)
  m2PriceReason           String?
  extraBeamPricePerM      Decimal @db.Decimal(14, 2)
  m2Cost                  Decimal @db.Decimal(14, 2)
  patternExtraCost        Decimal @db.Decimal(14, 2)
  manualExtraBeamsCost    Decimal @db.Decimal(14, 2)
  subtotal                Decimal @db.Decimal(14, 2)

  // ── Stage-② annotation (drawing→quote) ──
  // The box this room was drawn over on the source plan, normalized to
  // the image's natural size (each value 0..1: { x, y, w, h }).
  // annotationImagePath points at the project-owned copy of that drawing
  // so the record outlives the source chat. Null for hand-typed rooms.
  annotationBox       Json?
  annotationImagePath String?

  seq             Int      @default(0) // row display order within project

  createdAt       DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  orders  Order[] // an Order may snapshot a particular Calculation as primary

  @@index([projectId])
  @@map("calculations")
}

// ─────────────────────────────────────────────
// Order — replaces the old Quote model.
// Created by the Place Order ("Буюртма Бериш") action.
// ─────────────────────────────────────────────

model Order {
  id              String       @id @default(cuid())
  // Human-readable, monotonic per month: "2026-05-0001"
  orderNumber     String       @unique
  projectId       String       @unique // one Order per Project for now
  clientId        String
  primaryCalculationId String?

  status          OrderStatus       @default(PLACED)
  paymentState    OrderPaymentState @default(AWAITING_PAYMENT)
  // Sum of all CONFIRMED payments for this order. Recomputed by the
  // confirm/reject flows; never edited directly by the UI.
  confirmedPaid   Decimal           @default(0) @db.Decimal(14, 2)

  // Pricing snapshot — frozen at placement time
  roomsSubtotal   Decimal      @db.Decimal(14, 2)
  discountPercent Decimal      @default(0) @db.Decimal(5, 2)
  discountAmount  Decimal      @default(0) @db.Decimal(14, 2)
  deliveryCost    Decimal      @default(0) @db.Decimal(14, 2)
  otherCost       Decimal      @default(0) @db.Decimal(14, 2)
  totalPrice      Decimal      @db.Decimal(14, 2)

  // Capacity snapshot at placement time — denormalized so the calendar
  // can sum without joining calculations.
  totalArea       Decimal      @db.Decimal(10, 3) // sum of monolithArea across rooms
  totalBlocks     Int          @default(0)
  totalBeams      Int          @default(0)

  // Production / delivery scheduling
  scheduledAt     DateTime     // when the customer wants delivery / production day
  placedAt        DateTime     @default(now())
  productionStartedAt DateTime?
  deliveredAt     DateTime?
  paidAt          DateTime?
  canceledAt      DateTime?
  cancelReason    String?

  // Proof-of-delivery photo (truck loaded with the product)
  // — required by the UI before the IN_PRODUCTION → DELIVERED transition
  deliveryProofUrl        String?
  deliveryProofUploadedAt DateTime?

  // Single-truck loading (new flow)
  loadedPhotoUrl  String?
  loadedAt        DateTime?

  notes           String?

  project       Project       @relation(fields: [projectId], references: [id])
  client        Client        @relation(fields: [clientId], references: [id])
  primaryCalculation Calculation? @relation(fields: [primaryCalculationId], references: [id])
  events        OrderEvent[]
  stockMovements StockMovement[]
  // Cash-custody relations
  dispatch      Dispatch?      // 0-or-1 active dispatch (orderId is @unique on Dispatch)
  payments      Payment[]
  discrepancies Discrepancy[]
  drawingRequests DrawingRequest[]
  shipments     Shipment[]
  comments      Comment[]
  galleryPhotos GalleryPhoto[]

  @@index([status])
  @@index([paymentState])
  @@index([status, paymentState])
  @@index([clientId])
  @@index([scheduledAt])
  @@index([placedAt])
  @@map("orders")
}

// Append-only activity log on an Order.
model OrderEvent {
  id        String         @id @default(cuid())
  orderId   String
  type      OrderEventType
  actorId   String?
  message   String?
  payload   Json?          // type-specific data (from/to status, prev value, etc.)
  createdAt DateTime       @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  actor User? @relation(fields: [actorId], references: [id])

  @@index([orderId])
  @@index([createdAt])
  @@map("order_events")
}

// ─────────────────────────────────────────────
// Cash custody: Driver, Dispatch, Payment, Discrepancy
//
// The flow:
//   PLACED → IN_PRODUCTION (any role; production starts regardless of payment)
//   IN_PRODUCTION → DISPATCHED (any role; assigns a Driver, expectedCollection)
//   DISPATCHED → DELIVERED (any role; uploads truck photo + records cash)
//                 ↳ creates a Payment with status PENDING_CONFIRMATION,
//                   collectedById = driver, recordedById = operator
//   driver returns to office → operator clicks "Money received from driver"
//                 ↳ payment.handedOverToOfficeBy/At set; still PENDING
//   owner opens /payments → confirms or rejects
//                 ↳ on confirm: status CONFIRMED, recompute Order.confirmedPaid
//                   + Order.paymentState; if shortfall, create Discrepancy
//                 ↳ on reject: status REJECTED with reason
//
// Maker-checker separation: only ADMIN and OWNER can confirm/reject.
// All other roles record cash; they cannot confirm their own entries.
// ─────────────────────────────────────────────

model Driver {
  id        String   @id @default(cuid())
  name      String
  // Stored DIGITS-ONLY for stable lookup/dedup, like Client.phone.
  phone     String   @unique
  notes     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dispatches    Dispatch[]
  payments      Payment[]     @relation("PaymentCollector")
  discrepancies Discrepancy[]
  shipments     Shipment[]    @relation("ShipmentDriver")

  @@index([active, name])
  @@map("drivers")
}

model Dispatch {
  id                  String    @id @default(cuid())
  orderId             String    @unique  // one active dispatch per order in v1
  driverId            String?   // nullable — client may bring their own truck
  truckIdentifier     String?
  expectedCollection  Decimal   @db.Decimal(14, 2)
  notes               String?
  dispatchedById      String
  dispatchedAt        DateTime  @default(now())
  // Set when the driver returns to the office. Null while on the road.
  returnedAt          DateTime?

  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  driver       Driver? @relation(fields: [driverId], references: [id])
  dispatchedBy User    @relation("DispatchDispatcher", fields: [dispatchedById], references: [id])

  @@index([driverId, dispatchedAt])
  @@map("dispatches")
}

// Split-shipment: one row per truck when an order is divided across
// multiple vehicles. Created on-demand via the "Бўлиб юклаш" flow.
// Single-truck orders skip this model entirely and use Order.loadedPhotoUrl
// + the existing Dispatch model instead.
model Shipment {
  id              String         @id @default(cuid())
  orderId         String
  number          Int            // 1-based sequence within the order

  status          ShipmentStatus @default(PENDING)

  // Counts — null until operator fills the loading form.
  // JSON shape: Record<string, number>  e.g. { "3.3": 5, "4.3": 10 }
  loadedBeams     Json?
  loadedBlocks    Int?

  // Loaded truck photo
  loadedPhotoUrl  String?
  loadedAt        DateTime?

  // Optional driver assignment per shipment
  driverId             String?
  truckIdentifier      String?
  driverWillCollectCash Boolean  @default(false)
  cashToCollect        Decimal?  @db.Decimal(14, 2)
  dispatchedById       String?
  dispatchedAt         DateTime?

  deliveredAt     DateTime?
  notes           String?

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  order        Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  driver       Driver? @relation("ShipmentDriver",     fields: [driverId],       references: [id])
  dispatchedBy User?   @relation("ShipmentDispatcher", fields: [dispatchedById], references: [id])

  @@unique([orderId, number])
  @@index([orderId])
  @@map("shipments")
}

model Payment {
  id              String        @id @default(cuid())
  orderId         String
  amount          Decimal       @db.Decimal(14, 2)
  method          PaymentMethod
  status          PaymentStatus @default(PENDING_CONFIRMATION)

  // ── Chain of custody ──
  // Driver who took the cash from the customer (CASH only; null for transfers).
  collectedById          String?
  collectedAt            DateTime?
  // Operator who entered the row in the app.
  recordedById           String
  recordedAt             DateTime  @default(now())
  // Operator who physically received the cash from the driver at the office.
  handedOverToOfficeById String?
  handedOverToOfficeAt   DateTime?
  // Owner who confirmed the amount is correct.
  confirmedById          String?
  confirmedAt            DateTime?
  // Owner who rejected the row + the reason they gave.
  rejectedById           String?
  rejectedAt             DateTime?
  rejectionReason        String?

  // ── Adjustment audit ──
  // If the confirmer changed the amount on the form, we keep the original
  // here so the record explains the discrepancy.
  originalAmount         Decimal?  @db.Decimal(14, 2)
  adjustmentNote         String?

  notes                  String?

  order              Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  collectedByDriver  Driver? @relation("PaymentCollector", fields: [collectedById], references: [id])
  recordedBy         User    @relation("PaymentRecorder", fields: [recordedById], references: [id])
  handedOverTo       User?   @relation("PaymentHandedOverTo", fields: [handedOverToOfficeById], references: [id])
  confirmedBy        User?   @relation("PaymentConfirmer", fields: [confirmedById], references: [id])
  rejectedBy         User?   @relation("PaymentRejecter", fields: [rejectedById], references: [id])
  discrepancies      Discrepancy[]

  @@index([orderId])
  @@index([status, recordedAt])
  @@map("payments")
}

model Discrepancy {
  id              String              @id @default(cuid())
  orderId         String
  paymentId       String?            // the linked payment if confirmation produced one
  driverId        String?            // who collected from the customer
  expectedAmount  Decimal             @db.Decimal(14, 2)
  receivedAmount  Decimal             @db.Decimal(14, 2)
  shortfall       Decimal             @db.Decimal(14, 2)   // expected - received (always positive)
  status          DiscrepancyStatus   @default(OPEN)
  reportedById    String              // confirmer who flagged it
  reportedAt      DateTime            @default(now())
  resolvedById    String?
  resolvedAt      DateTime?
  resolutionNote  String?

  order      Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  payment    Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  driver     Driver?  @relation(fields: [driverId], references: [id], onDelete: SetNull)
  reportedBy User    @relation("DiscrepancyReporter", fields: [reportedById], references: [id])
  resolvedBy User?   @relation("DiscrepancyResolver", fields: [resolvedById], references: [id])

  @@index([driverId, reportedAt])
  @@index([status])
  @@index([orderId])
  @@map("discrepancies")
}

// ─────────────────────────────────────────────
// Audit trail for the contact-export feature.
// One row per export the operator performs — keeps a permanent record of
// who handed out which client contacts when, in case of a privacy
// complaint or compliance review.
// ─────────────────────────────────────────────

model ExportEvent {
  id         String   @id @default(cuid())
  userId     String
  clientIds  String[] // Postgres text[] of Client.id values
  exportedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([exportedAt])
  @@map("export_events")
}

model AppConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt

  @@map("app_config")
}

// ─────────────────────────────────────────────
// Inventory module
//
// One InventoryItem row per (kind, beamLength) pair:
//   - one BEAM row per distinct manufactured length (4.30, 5.20, 6.30, …)
//   - one BLOCK row with beamLength = NULL
//
// Quantity is incremented by ProductionEntries (factory output) and
// decremented when an order's status flips to DELIVERED. Negative stock is
// allowed (records a STOCK_WARNING OrderEvent) so deliveries are never
// blocked by an under-recorded production log. Manual adjustments by ADMIN
// keep the books straight.
// ─────────────────────────────────────────────

model InventoryItem {
  id                 String        @id @default(cuid())
  kind               InventoryKind
  // For BEAM: manufactured length in meters, rounded to 2 decimals (e.g. 4.30).
  // For BLOCK: NULL (one row only, lookup by kind).
  beamLength         Decimal?      @db.Decimal(10, 2)
  quantity           Int           @default(0)
  lowStockThreshold  Int           @default(10)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  movements StockMovement[]

  // One row per distinct (kind, length). Postgres treats NULLs as distinct
  // by default, but for our use we want exactly one BLOCK row — so the seed
  // and inventory lib handle the BLOCK case by always upserting via this
  // composite key.
  @@unique([kind, beamLength], name: "kind_beamLength")
  @@index([kind])
  @@map("inventory_items")
}

model ProductionEntry {
  id           String   @id @default(cuid())
  producedAt   DateTime @default(now())
  recordedById String?
  notes        String?
  createdAt    DateTime @default(now())

  recordedBy User?           @relation(fields: [recordedById], references: [id])
  lines      ProductionLine[]
  movements  StockMovement[]

  @@index([producedAt])
  @@index([recordedById])
  @@map("production_entries")
}

model ProductionLine {
  id                String        @id @default(cuid())
  productionEntryId String
  kind              InventoryKind
  beamLength        Decimal?      @db.Decimal(10, 2)
  quantity          Int

  productionEntry ProductionEntry @relation(fields: [productionEntryId], references: [id], onDelete: Cascade)

  @@index([productionEntryId])
  @@map("production_lines")
}

// Append-only ledger of stock changes. Every increment / decrement leaves
// a row here keyed back to the cause (production entry, order, or null
// for manual adjustments).
model StockMovement {
  id                String              @id @default(cuid())
  inventoryItemId   String
  // +N for production / restock; -N for delivery / negative manual adjustment
  change            Int
  // The resulting quantity AFTER this movement was applied — saved here so
  // the timeline can be reconstructed without replaying every prior row.
  resultingQuantity Int
  reason            StockMovementReason
  productionEntryId String?
  orderId           String?
  actorId           String?
  note              String?
  createdAt         DateTime            @default(now())

  inventoryItem   InventoryItem    @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  productionEntry ProductionEntry? @relation(fields: [productionEntryId], references: [id], onDelete: SetNull)
  order           Order?           @relation(fields: [orderId], references: [id], onDelete: SetNull)
  actor           User?            @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([inventoryItemId])
  @@index([orderId])
  @@index([productionEntryId])
  @@index([createdAt])
  @@map("stock_movements")
}

// ─────────────────────────────────────────────
// Blender Bridge — owner-only feature.
//
// A DrawingRequest is a queue entry created when the owner clicks
// "Send to Blender" on a saved Project or an Order detail page.
// The self-hosted ws-bridge service (see ws-bridge/server.js) picks
// up PENDING rows, pushes them over WebSocket to a connected Blender
// instance, and on ACK marks them DELIVERED.
//
// `roomsJson` is a snapshot of the rooms array at the moment the
// request was created — so if the operator later edits the project
// or order, the snapshot the Blender plug-in received is preserved.
// The shape inside roomsJson is the normalized snake_case Blender
// shape (see src/lib/blender-bridge/normalize-rooms.ts).
// ─────────────────────────────────────────────

model DrawingRequest {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Source: exactly one of orderId or projectId is non-null. The API
  // layer enforces this (no DB-level check; one nullable FK each is
  // enough for Postgres + simpler than a CHECK constraint).
  orderId      String?
  order        Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  // Snapshot of the rooms array sent to Blender. Stored as a JSON
  // string (not Postgres jsonb) because the ws-bridge service reads
  // it via raw SQL and forwards it verbatim — keeping the field as
  // a plain string avoids serialization round-trips on the bridge.
  roomsJson    String

  status        DrawingRequestStatus @default(PENDING)
  deliveredAt   DateTime?
  errorMessage  String?

  // Populated by ws-bridge when DRAWING_RESULT arrives from the addon.
  // pdfStorageKey is a relative path ("drawings/<id>.pdf") under the
  // DRAWINGS_DIR mount shared between ws-bridge and app containers.
  pdfStorageKey String?
  pdfSizeBytes  Int?
  pageCount     Int?
  renderMs      Int?

  createdById  String
  createdBy    User     @relation(fields: [createdById], references: [id])

  @@index([status, createdAt])
  @@index([createdById, createdAt])
  @@index([orderId])
  @@index([projectId])
  @@map("drawing_requests")
}

// ──────────────────────────────────────────────────────────────────
// Comments — freeform threaded notes attached to Orders OR Projects.
//
// Polymorphic: exactly one of orderId / projectId is non-null. The
// API layer enforces mutual exclusivity (same pattern as
// DrawingRequest). Soft-delete via deletedAt; rows are never hard
// removed. Edits prepend the old body to editHistory for audit.
// ──────────────────────────────────────────────────────────────────
model Comment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Source: exactly one non-null.
  orderId   String?
  order     Order?   @relation(fields: [orderId],   references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  authorId  String
  author    User     @relation("CommentAuthor", fields: [authorId], references: [id])

  // Raw text; frontend resolves @mentions to links at display time.
  body      String   @db.Text

  // User IDs extracted from @mentions in body at write time. Used for
  // notification fan-out without re-parsing the body on every read.
  mentionedUserIds String[] @default([])

  // Append-only edit history. Each element: { body: string, editedAt: ISO }
  editHistory Json[] @default([])

  // Soft delete. When set, the row is hidden from queries but kept
  // for audit. Hard deletes are forbidden by convention.
  deletedAt   DateTime?
  deletedById String?
  deletedBy   User?    @relation("CommentDeleter", fields: [deletedById], references: [id])

  @@index([orderId,   createdAt])
  @@index([projectId, createdAt])
  @@index([authorId,  createdAt])
  @@index([deletedAt, createdAt])
  @@map("comments")
}

// ──────────────────────────────────────────────────────────────────
// Notifications — per-user in-app notification feed.
//
// One row per recipient. Pre-rendered bilingual title/body for fast
// display. Polymorphic reference: at most one of orderId/paymentId
// is set. No FK on those — notifications survive their target's
// deletion so the audit trail is preserved.
// ──────────────────────────────────────────────────────────────────
enum NotificationType {
  ORDER_PLACED
  ORDER_STATUS_CHANGED
  DELIVERY_PROOF_UPLOADED
  PAYMENT_RECORDED
  PAYMENT_CONFIRMED
  PAYMENT_REJECTED
  COMMENT_MENTION
  NEW_COMMENT
}

model Notification {
  id        String           @id @default(cuid())
  createdAt DateTime         @default(now())

  type      NotificationType

  userId    String
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Pre-rendered bilingual title (e.g. "Янги буюртма #2026-05-0042 · New order #2026-05-0042")
  title     String
  body      String?

  // Polymorphic target — no FK constraints (intentional, see comment above)
  orderId   String?
  paymentId String?
  projectId String?
  commentId String?

  // Unread state per-user.
  readAt    DateTime?

  @@index([userId, readAt, createdAt])
  @@index([userId, createdAt])
  @@index([orderId])
  @@map("notifications")
}

// ──────────────────────────────────────────────────────────────────
// Gallery photos — append-only index of every photo uploaded to any
// order. Mirrors the canonical fields on Order/Shipment so the
// gallery feed is one indexed table scan instead of a UNION across
// three columns.
//
// Populated by each upload route (delivery-proof, load, shipment
// load) inside the same transaction that writes the URL to the
// canonical field. The original String? fields on Order/Shipment
// stay as the source of truth for the invoice + delivery flow.
// ──────────────────────────────────────────────────────────────────
enum GalleryPhotoKind {
  LOADED          // Order.loadedPhotoUrl — single-truck loaded photo
  DELIVERY_PROOF  // Order.deliveryProofUrl — proof of delivery
  SHIPMENT_LOADED // Shipment.loadedPhotoUrl — split-shipment truck photo
}

model GalleryPhoto {
  id           String           @id @default(cuid())
  orderId      String
  shipmentId   String?
  kind         GalleryPhotoKind
  url          String
  uploadedAt   DateTime         @default(now())
  uploadedById String?

  order        Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  uploadedBy   User? @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([uploadedAt(sort: Desc)])
  @@index([orderId])
  @@index([kind])
  @@map("gallery_photos")
}

// ──────────────────────────────────────────────────────────────────
// Telegram Business Inbox
// ──────────────────────────────────────────────────────────────────

enum ConversationChannel {
  TELEGRAM
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MediaKind {
  IMAGE
  VIDEO
  VIDEO_NOTE
  VOICE
  AUDIO
  DOCUMENT
  LOCATION
  OTHER
}

model Conversation {
  id                   String              @id @default(cuid())
  channel              ConversationChannel @default(TELEGRAM)
  externalId           String              // Telegram chat id (the chat to reply to)
  businessConnectionId String?
  displayName          String
  username             String?
  sharedContactPhone   String?             // digits-only; from a client's shared-contact message
  lastMessageAt        DateTime
  lastSnippet          String              @default("")
  unread               Boolean             @default(true)
  createdAt            DateTime            @default(now())
  messages             Message[]
  projects             Project[]

  @@unique([channel, externalId])
  @@index([lastMessageAt])
}

model Message {
  id             String           @id @default(cuid())
  conversationId String
  direction      MessageDirection
  text           String?
  mediaKind      MediaKind?
  mediaPath      String?
  mediaName      String?
  mediaMeta      Json?
  telegramMsgId  String?
  mediaGroupId   String?
  sentById       String?          // operator id (no FK; owner-only inbox)
  failed         Boolean          @default(false)
  createdAt      DateTime         @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([conversationId, mediaGroupId])
  @@unique([conversationId, telegramMsgId])
}

// ══════════════════════════════════════════════════════════════════
// ГАЗОБЛОК (Aerated-concrete wall blocks) — a SEPARATE product line.
//
// Unlike beam-and-block flooring there is NO room geometry, pattern, or
// pitch math: a customer simply buys a quantity of blocks of given sizes.
// The whole line is namespaced `Gazoblok*` so it never collides with the
// floor INFILL block (InventoryKind.BLOCK). Orders are always separate
// from floor Orders but link to the SAME Client.
//
// Catalog: several sizes, ONE density grade (the grade label lives in
// AppConfig key "gazoblok.grade"). Operator sets a price PER BLOCK per
// size; the per-m³ price is DERIVED in src/services/gazoblok-engine.ts.
//
// Payment/delivery is intentionally simpler than floor orders (no driver
// cash-custody / dispatch / discrepancy / split-shipment): a payment is
// recorded then confirmed, delivery is the status flow + one proof photo,
// and stock decrements when status flips to DELIVERED.
// ══════════════════════════════════════════════════════════════════

enum GazoblokOrderStatus {
  PLACED          // Буюртма берилди
  IN_PRODUCTION   // Ишлаб чиқарилмоқда (optional middle state)
  DELIVERED       // Етказиб берилди — stock decrements here
  CANCELED        // Бекор қилинди
}

enum GazoblokStockReason {
  PRODUCTION
  SALE                  // -N when an order is delivered
  MANUAL_ADJUSTMENT
  CANCELLATION_RESTOCK  // +N when a delivered order is canceled
}

// Catalog row — one per block size (single density grade).
model GazoblokProduct {
  id            String   @id @default(cuid())
  label         String   // e.g. "600×300×200"
  // Dimensions in METERS, used for m³ derivation + the wall estimator.
  lengthM       Decimal  @db.Decimal(10, 3)
  heightM       Decimal  @db.Decimal(10, 3)
  thicknessM    Decimal  @db.Decimal(10, 3) // = wall thickness this block builds
  // Operator-set price per single block (UZS). m³ price is derived.
  pricePerBlock Decimal  @db.Decimal(14, 2)
  lowStockThreshold Int  @default(50)
  active        Boolean  @default(true)
  seq           Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  stock           GazoblokStock?
  orderLines      GazoblokOrderLine[]
  productionLines GazoblokProductionLine[]
  stockMovements  GazoblokStockMovement[]

  @@index([active, seq])
  @@map("gazoblok_products")
}

// Current on-hand quantity per catalog row (one-to-one with product).
model GazoblokStock {
  id        String   @id @default(cuid())
  productId String   @unique
  quantity  Int      @default(0)
  updatedAt DateTime @updatedAt

  product GazoblokProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("gazoblok_stock")
}

// Append-only stock ledger, mirrors StockMovement but keyed by product.
model GazoblokStockMovement {
  id                String              @id @default(cuid())
  productId         String
  change            Int                 // +N production/restock, -N sale/neg-adjust
  resultingQuantity Int
  reason            GazoblokStockReason
  productionEntryId String?
  orderId           String?
  actorId           String?
  note              String?
  createdAt         DateTime            @default(now())

  product         GazoblokProduct          @relation(fields: [productId], references: [id], onDelete: Cascade)
  productionEntry GazoblokProductionEntry? @relation(fields: [productionEntryId], references: [id], onDelete: SetNull)
  order           GazoblokOrder?           @relation(fields: [orderId], references: [id], onDelete: SetNull)
  actor           User?                    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([orderId])
  @@index([productionEntryId])
  @@index([createdAt])
  @@map("gazoblok_stock_movements")
}

model GazoblokProductionEntry {
  id           String   @id @default(cuid())
  producedAt   DateTime @default(now())
  recordedById String?
  notes        String?
  createdAt    DateTime @default(now())

  recordedBy User?                    @relation(fields: [recordedById], references: [id])
  lines      GazoblokProductionLine[]
  movements  GazoblokStockMovement[]

  @@index([producedAt])
  @@map("gazoblok_production_entries")
}

model GazoblokProductionLine {
  id        String @id @default(cuid())
  entryId   String
  productId String
  quantity  Int

  entry   GazoblokProductionEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  product GazoblokProduct         @relation(fields: [productId], references: [id])

  @@index([entryId])
  @@map("gazoblok_production_lines")
}

model GazoblokOrder {
  id          String              @id @default(cuid())
  orderNumber String              @unique // "B-2026-06-0001"
  clientId    String

  status        GazoblokOrderStatus @default(PLACED)
  paymentState  OrderPaymentState   @default(AWAITING_PAYMENT)
  confirmedPaid Decimal             @default(0) @db.Decimal(14, 2)

  // Pricing snapshot — frozen at placement
  linesSubtotal   Decimal @db.Decimal(14, 2)
  discountPercent Decimal @default(0) @db.Decimal(5, 2)
  discountAmount  Decimal @default(0) @db.Decimal(14, 2)
  deliveryCost    Decimal @default(0) @db.Decimal(14, 2)
  totalPrice      Decimal @db.Decimal(14, 2)

  // Denormalized capacity
  totalBlocks   Int     @default(0)
  totalVolumeM3 Decimal @default(0) @db.Decimal(10, 3)

  scheduledAt  DateTime?
  placedAt     DateTime  @default(now())
  deliveredAt  DateTime?
  canceledAt   DateTime?
  cancelReason String?

  deliveryProofUrl        String?
  deliveryProofUploadedAt DateTime?

  notes String?

  client         Client                 @relation(fields: [clientId], references: [id])
  lines          GazoblokOrderLine[]
  payments       GazoblokPayment[]
  events         GazoblokOrderEvent[]
  stockMovements GazoblokStockMovement[]

  @@index([status])
  @@index([clientId])
  @@index([placedAt])
  @@map("gazoblok_orders")
}

// One line per product on an order. Snapshots label + unit price so the
// line survives later catalog edits / deletion.
model GazoblokOrderLine {
  id           String  @id @default(cuid())
  orderId      String
  productId    String?
  productLabel String
  unitPrice    Decimal @db.Decimal(14, 2) // price per block at placement
  quantity     Int
  lineTotal    Decimal @db.Decimal(14, 2)

  order   GazoblokOrder    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product GazoblokProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@map("gazoblok_order_lines")
}

// Simplified payment — recorded then confirmed (no driver custody chain).
model GazoblokPayment {
  id      String        @id @default(cuid())
  orderId String
  amount  Decimal       @db.Decimal(14, 2)
  method  PaymentMethod
  status  PaymentStatus @default(PENDING_CONFIRMATION)

  recordedById  String?
  recordedAt    DateTime  @default(now())
  confirmedById String?
  confirmedAt   DateTime?
  notes         String?

  order       GazoblokOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  recordedBy  User?         @relation("GazoblokPaymentRecorder",  fields: [recordedById],  references: [id])
  confirmedBy User?         @relation("GazoblokPaymentConfirmer", fields: [confirmedById], references: [id])

  @@index([orderId])
  @@index([status, recordedAt])
  @@map("gazoblok_payments")
}

// Append-only activity log on a Gazoblok order.
model GazoblokOrderEvent {
  id        String   @id @default(cuid())
  orderId   String
  type      String   // "ORDER_PLACED" | "STATUS_CHANGED" | "PAYMENT_RECORDED" | ...
  actorId   String?
  message   String?
  payload   Json?
  createdAt DateTime @default(now())

  order GazoblokOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  actor User?         @relation(fields: [actorId], references: [id])

  @@index([orderId])
  @@index([createdAt])
  @@map("gazoblok_order_events")
}
