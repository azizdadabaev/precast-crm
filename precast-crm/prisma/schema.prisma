// Precast Concrete CRM - Prisma Schema
// Beam-and-Block manufacturing system

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  ADMIN
  SALES
  ENGINEER
}

enum Language {
  UZ
  RU
}

enum DealStage {
  NEW_LEAD
  CONTACTED
  CALCULATION
  QUOTE_SENT
  WON
  LOST
}

enum DealStatus {
  OPEN
  WON
  LOST
}

enum ShapeType {
  RECTANGULAR
  TRAPEZOIDAL
  IRREGULAR
}

enum LayoutPattern {
  GB    // Г-Б — alternating, equal beam and block rows
  BGB   // Б-Г-Б — extra closing beam
  GBG   // Г-Б-Г — extra closing block row
}

enum ProjectStatus {
  DRAFT      // saved calculation, not yet placed as an order
  ORDERED    // an Order exists for this project
  ARCHIVED   // soft-deleted draft
}

enum OrderStatus {
  PLACED          // Буюртма Берилди — newly placed
  IN_PRODUCTION   // Ишлаб чиқарилмоқда
  DELIVERED       // Етказиб берилди
  PAID            // Тўланди
  CANCELED        // Бекор қилинди
}

enum PaymentStatus {
  PAID
  PARTIAL
  UNPAID
}

enum OrderEventType {
  ORDER_PLACED
  STATUS_CHANGED
  SCHEDULED_DATE_CHANGED
  DISCOUNT_APPLIED
  ORDER_CANCELED
  NOTE_ADDED
  STOCK_WARNING
}

enum InventoryKind {
  BEAM
  BLOCK
}

enum StockMovementReason {
  PRODUCTION
  DELIVERY
  MANUAL_ADJUSTMENT
  CANCELLATION_RESTOCK
}

// Privacy gate for the contact-export feature: a client can only be
// included in an export if their consent state is GRANTED. NOT_ASKED is
// the default for existing rows and any new client until the operator
// explicitly records the answer.
enum ReferenceConsent {
  NOT_ASKED
  GRANTED
  DENIED
}

// ─────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(SALES)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  deals             Deal[]             @relation("AssignedDeals")
  orderEvents       OrderEvent[]
  productionEntries ProductionEntry[]
  stockMovements    StockMovement[]
  exportEvents      ExportEvent[]

  @@map("users")
}

model Client {
  id        String   @id @default(cuid())
  name      String
  // Stored DIGITS-ONLY for stable lookup/dedup. Display formats it back.
  phone     String   @unique
  address   String?  // "Манзил" (renamed from `location`)
  language  Language @default(UZ)
  source    String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Reference-export privacy gate: GRANTED means the client agreed to be
  // listed when an operator exports contacts for a new prospect to visit
  // their finished slab. NOT_ASKED is the default — operators must
  // explicitly mark the answer.
  referenceConsent  ReferenceConsent @default(NOT_ASKED)
  consentNote       String?
  consentUpdatedAt  DateTime?

  deals    Deal[]
  projects Project[]
  orders   Order[]

  @@index([phone])
  @@index([createdAt])
  @@index([referenceConsent])
  @@map("clients")
}

model Deal {
  id           String     @id @default(cuid())
  clientId     String
  stage        DealStage  @default(NEW_LEAD)
  status       DealStatus @default(OPEN)
  value        Decimal    @default(0) @db.Decimal(14, 2)
  assignedToId String?
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  client     Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assignedTo User?     @relation("AssignedDeals", fields: [assignedToId], references: [id])
  projects   Project[]
  payments   Payment[]

  @@index([stage])
  @@index([status])
  @@index([clientId])
  @@map("deals")
}

model Project {
  id         String        @id @default(cuid())
  // Optional now: Calculations page can save a draft BEFORE a Deal exists.
  // The Deal is materialized when an order is placed.
  dealId     String?
  // Hardened client link (set when ordered, or when the operator picks an
  // existing client during the call). Null while we have only tentative info.
  clientId   String?

  name       String?
  shapeType  ShapeType     @default(RECTANGULAR)
  dimensions Json
  status     ProjectStatus @default(DRAFT)

  // Tentative client info captured during the phone call.
  // Once the order is placed (or operator picks an existing client),
  // this gets reconciled into a Client row and these fields are cleared.
  tentativeClientName    String?
  tentativeClientPhone   String? // stored DIGITS-ONLY for dedup
  tentativeClientAddress String?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  deal         Deal?         @relation(fields: [dealId], references: [id], onDelete: SetNull)
  client       Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  calculations Calculation[]
  orders       Order[]

  @@index([status])
  @@index([dealId])
  @@index([clientId])
  @@index([tentativeClientPhone])
  @@map("projects")
}

model Calculation {
  id              String        @id @default(cuid())
  projectId       String
  name            String? // Room label (e.g. "Kitchen")

  // ── Inputs (snapshot for reproducibility) ──
  innerWidth      Decimal       @db.Decimal(10, 3)
  innerLength     Decimal       @db.Decimal(10, 3)
  bearing         Decimal       @default(0.15) @db.Decimal(10, 3)
  correction      Decimal       @default(0) @db.Decimal(10, 3)
  extraBeams      Int           @default(0)
  forceStartBeam  Boolean       @default(false)
  patternOverride LayoutPattern? // user-picked; null = auto

  // ── Pitch math ──
  pitches         Int
  remainder       Decimal       @db.Decimal(10, 3)
  pattern         LayoutPattern // chosen (after override + force_start_beam)
  patternAuto     LayoutPattern // what auto-pick would have chosen

  // ── Geometry ──
  beamLength      Decimal       @db.Decimal(10, 3)
  blocksPerRow    Int
  beamCount       Int
  blockRows       Int
  totalBlocks     Int

  monolithLength  Decimal       @db.Decimal(10, 3)
  billedLength    Decimal       @db.Decimal(10, 3)

  monolithArea    Decimal       @db.Decimal(10, 3)
  billedArea      Decimal       @db.Decimal(10, 3)

  concreteVolume  Decimal       @db.Decimal(10, 3)

  // ── Pricing snapshot (UZS) ──
  m2Price                 Decimal @db.Decimal(14, 2)
  extraBeamPricePerM      Decimal @db.Decimal(14, 2)
  m2Cost                  Decimal @db.Decimal(14, 2)
  patternExtraCost        Decimal @db.Decimal(14, 2)
  manualExtraBeamsCost    Decimal @db.Decimal(14, 2)
  subtotal                Decimal @db.Decimal(14, 2)

  createdAt       DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  orders  Order[] // an Order may snapshot a particular Calculation as primary

  @@index([projectId])
  @@map("calculations")
}

// ─────────────────────────────────────────────
// Order — replaces the old Quote model.
// Created by the Place Order ("Буюртма Бериш") action.
// ─────────────────────────────────────────────

model Order {
  id              String       @id @default(cuid())
  // Human-readable, monotonic per month: "2026-05-0001"
  orderNumber     String       @unique
  projectId       String       @unique // one Order per Project for now
  clientId        String
  primaryCalculationId String?

  status          OrderStatus  @default(PLACED)

  // Pricing snapshot — frozen at placement time
  roomsSubtotal   Decimal      @db.Decimal(14, 2)
  discountPercent Decimal      @default(0) @db.Decimal(5, 2)
  discountAmount  Decimal      @default(0) @db.Decimal(14, 2)
  deliveryCost    Decimal      @default(0) @db.Decimal(14, 2)
  otherCost       Decimal      @default(0) @db.Decimal(14, 2)
  totalPrice      Decimal      @db.Decimal(14, 2)

  // Capacity snapshot at placement time — denormalized so the calendar
  // can sum without joining calculations.
  totalArea       Decimal      @db.Decimal(10, 3) // sum of monolithArea across rooms
  totalBlocks     Int          @default(0)
  totalBeams      Int          @default(0)

  // Production / delivery scheduling
  scheduledAt     DateTime     // when the customer wants delivery / production day
  placedAt        DateTime     @default(now())
  productionStartedAt DateTime?
  deliveredAt     DateTime?
  paidAt          DateTime?
  canceledAt      DateTime?
  cancelReason    String?

  // Proof-of-delivery photo (truck loaded with the product)
  // — required by the UI before the IN_PRODUCTION → DELIVERED transition
  deliveryProofUrl        String?
  deliveryProofUploadedAt DateTime?

  notes           String?

  project       Project       @relation(fields: [projectId], references: [id])
  client        Client        @relation(fields: [clientId], references: [id])
  primaryCalculation Calculation? @relation(fields: [primaryCalculationId], references: [id])
  events        OrderEvent[]
  stockMovements StockMovement[]

  @@index([status])
  @@index([clientId])
  @@index([scheduledAt])
  @@index([placedAt])
  @@map("orders")
}

// Append-only activity log on an Order.
model OrderEvent {
  id        String         @id @default(cuid())
  orderId   String
  type      OrderEventType
  actorId   String?
  message   String?
  payload   Json?          // type-specific data (from/to status, prev value, etc.)
  createdAt DateTime       @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  actor User? @relation(fields: [actorId], references: [id])

  @@index([orderId])
  @@index([createdAt])
  @@map("order_events")
}

model Payment {
  id        String        @id @default(cuid())
  dealId    String
  amount    Decimal       @db.Decimal(14, 2)
  status    PaymentStatus @default(UNPAID)
  method    String?
  reference String?
  paidAt    DateTime?
  createdAt DateTime      @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@index([status])
  @@map("payments")
}

// ─────────────────────────────────────────────
// Audit trail for the contact-export feature.
// One row per export the operator performs — keeps a permanent record of
// who handed out which client contacts when, in case of a privacy
// complaint or compliance review.
// ─────────────────────────────────────────────

model ExportEvent {
  id         String   @id @default(cuid())
  userId     String
  clientIds  String[] // Postgres text[] of Client.id values
  exportedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([exportedAt])
  @@map("export_events")
}

model AppConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt

  @@map("app_config")
}

// ─────────────────────────────────────────────
// Inventory module
//
// One InventoryItem row per (kind, beamLength) pair:
//   - one BEAM row per distinct manufactured length (4.30, 5.20, 6.30, …)
//   - one BLOCK row with beamLength = NULL
//
// Quantity is incremented by ProductionEntries (factory output) and
// decremented when an order's status flips to DELIVERED. Negative stock is
// allowed (records a STOCK_WARNING OrderEvent) so deliveries are never
// blocked by an under-recorded production log. Manual adjustments by ADMIN
// keep the books straight.
// ─────────────────────────────────────────────

model InventoryItem {
  id                 String        @id @default(cuid())
  kind               InventoryKind
  // For BEAM: manufactured length in meters, rounded to 2 decimals (e.g. 4.30).
  // For BLOCK: NULL (one row only, lookup by kind).
  beamLength         Decimal?      @db.Decimal(10, 2)
  quantity           Int           @default(0)
  lowStockThreshold  Int           @default(10)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  movements StockMovement[]

  // One row per distinct (kind, length). Postgres treats NULLs as distinct
  // by default, but for our use we want exactly one BLOCK row — so the seed
  // and inventory lib handle the BLOCK case by always upserting via this
  // composite key.
  @@unique([kind, beamLength], name: "kind_beamLength")
  @@index([kind])
  @@map("inventory_items")
}

model ProductionEntry {
  id           String   @id @default(cuid())
  producedAt   DateTime @default(now())
  recordedById String?
  notes        String?
  createdAt    DateTime @default(now())

  recordedBy User?           @relation(fields: [recordedById], references: [id])
  lines      ProductionLine[]
  movements  StockMovement[]

  @@index([producedAt])
  @@index([recordedById])
  @@map("production_entries")
}

model ProductionLine {
  id                String        @id @default(cuid())
  productionEntryId String
  kind              InventoryKind
  beamLength        Decimal?      @db.Decimal(10, 2)
  quantity          Int

  productionEntry ProductionEntry @relation(fields: [productionEntryId], references: [id], onDelete: Cascade)

  @@index([productionEntryId])
  @@map("production_lines")
}

// Append-only ledger of stock changes. Every increment / decrement leaves
// a row here keyed back to the cause (production entry, order, or null
// for manual adjustments).
model StockMovement {
  id                String              @id @default(cuid())
  inventoryItemId   String
  // +N for production / restock; -N for delivery / negative manual adjustment
  change            Int
  // The resulting quantity AFTER this movement was applied — saved here so
  // the timeline can be reconstructed without replaying every prior row.
  resultingQuantity Int
  reason            StockMovementReason
  productionEntryId String?
  orderId           String?
  actorId           String?
  note              String?
  createdAt         DateTime            @default(now())

  inventoryItem   InventoryItem    @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  productionEntry ProductionEntry? @relation(fields: [productionEntryId], references: [id], onDelete: SetNull)
  order           Order?           @relation(fields: [orderId], references: [id], onDelete: SetNull)
  actor           User?            @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([inventoryItemId])
  @@index([orderId])
  @@index([productionEntryId])
  @@index([createdAt])
  @@map("stock_movements")
}
